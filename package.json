{
  "name": "pi-agent-resource",
  "version": "1.0.0",
  "description": "This extension is useful for making agent skills, propmts and subagents",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:related": "vitest related"
  },
  "keywords": [
    "pi-package"
  ],
  "author": "Shelton Louis",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "extensions",
      "extensions/!*.test.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.2",
    "@mariozechner/pi-tui": "^0.67.2",
    "valibot": "^1.3.1"
  }
}
